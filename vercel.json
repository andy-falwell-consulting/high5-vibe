{
  "rewrites": [
    { "source": "/fmi/:path*", "destination": "/api/proxy?prefix=fmi&path=:path*" },
    { "source": "/Streaming_SSL/:path*", "destination": "/api/proxy?prefix=Streaming_SSL&path=:path*" },
    { "source": "/oauth/:path*", "destination": "/api/proxy?prefix=oauth&path=:path*" },
    { "source": "/fmws/:path*", "destination": "/api/proxy?prefix=fmws&path=:path*" }
  ],
  "crons": [
    { "path": "/api/sync?db=High5_Core4", "schedule": "*/5 * * * *" },
    { "path": "/api/sync?db=High5_Core4_Dev", "schedule": "*/5 * * * *" },
    { "path": "/api/qbo-invoice-sync?db=High5_Core4", "schedule": "*/5 * * * *" },
    { "path": "/api/qbo-invoice-sync?db=High5_Core4_Dev", "schedule": "*/5 * * * *" },
    { "path": "/api/replica-reconcile?db=High5_Core4", "schedule": "0 * * * *" },
    { "path": "/api/replica-reconcile?db=High5_Core4_Dev", "schedule": "0 * * * *" }
  ]
}
